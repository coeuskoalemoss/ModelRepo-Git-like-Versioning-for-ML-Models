# ─────────────────────────────────────────────
#  ModelRepo — .gitignore
# ─────────────────────────────────────────────

# Model weights — never commit binary weight files to git
# Use ModelRepo itself to version these
*.pt
*.pth
*.bin
*.ckpt
*.safetensors
*.npy
*.npz
*.h5
*.hdf5
*.pb
*.onnx
*.tflite
*.pkl
*.pickle

# ModelRepo data directory
# The ~/.modelrepo folder lives outside the project,
# but guard against it being created locally too
.modelrepo/

# Environment restoration artefacts (generated by env_lock.py)
.venv_*/
restore_env_*.sh
requirements_*.txt
*_requirements.txt

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
venv/
env/
ENV/
.env

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover

# Jupyter notebooks checkpoints
.ipynb_checkpoints/
*.ipynb

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs and temp files
*.log
*.tmp
*.temp
tmp/
temp/
logs/

# Local config overrides
.env.local
config.local.py